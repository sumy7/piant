{
  "compilerOptions": {
    "target": "ES2015",
    "jsx": "preserve",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "sourceMap": false,
    "rootDir": "src",
    "outDir": "dist",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src", "src/jsx.d.ts"]
}
